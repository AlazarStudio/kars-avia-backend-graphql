# ══════════════════════════════════════════════════════════════
#  KarsAvia Backend — пример переменных окружения (.env.example)
#  Скопируйте в .env и заполните своими значениями.
# ══════════════════════════════════════════════════════════════

# ── База данных ────────────────────────────────────────────────
# Для локального запуска (3 узла MongoDB):
DATABASE_URL="mongodb://localhost:27017,localhost:27018,localhost:27019/avia-db?replicaSet=rs0"
# Для Docker Compose:
# DATABASE_URL="mongodb://mongo:27017/avia-db?replicaSet=rs0&directConnection=true"

OLD_DATABASE_URL="mongodb://localhost:27017,localhost:27018,localhost:27019/avia-db-old?replicaSet=rs0"
DB_NAME="avia-db"

# ── Сервер ────────────────────────────────────────────────────
NODE_ENV="dev"               # "dev" или "production"
WS_KEEPALIVE_MS="12000"      # интервал пинга WebSocket (мс)
USER_IDLE_TIMEOUT_MS="600000"           # офлайн после неактивности (мс), по умолчанию 10 мин
PRESENCE_CLEANUP_INTERVAL_MS="120000"   # интервал cron-проверки (мс)
USER_LAST_SEEN_DEBOUNCE_MS="60000"      # debounce записи lastSeen (мс)

# ── Безопасность ──────────────────────────────────────────────
JWT_SECRET="your-strong-secret-key-here"
ALLOWED_ORIGINS='["https://yourdomain.com","https://www.yourdomain.com"]'

# ── Email ─────────────────────────────────────────────────────
EMAIL_ENABLED="false"        # "true" — реальная отправка; в dev все письма идут на EMAIL_RECEIVER
EMAIL_USER="noreply@yourdomain.ru"
EMAIL_PASSWORD="smtp-password"
EMAIL_RECEIVER="admin@yourdomain.ru"  # в dev — единственный получатель при EMAIL_ENABLED=true
EMAIL_RESIEVER="admin@yourdomain.ru"
EMAIL_KARS="kars@yourdomain.ru"
EMAIL_AVIA="avia@yourdomain.ru"
EMAIL_HOTEL="hotel@yourdomain.ru"

# ── Публичный фронтенд и письма auth (REST /api/auth, подтверждение email) ──
FRONTEND_URL="https://yourdomain.com"
SUPPORT_EMAIL="support@yourdomain.ru"
SERVICE_NAME="Kars Avia"

# ── SSL (только для server.js / HTTPS-режима) ─────────────────
SERVER_KEY="/etc/letsencrypt/live/yourdomain/privkey.pem"
SERVER_CERT="/etc/letsencrypt/live/yourdomain/cert.pem"
SERVER_CA="/etc/letsencrypt/live/yourdomain/chain.pem"

# ── Опциональные сервисы ──────────────────────────────────────
REDIS_URL="redis://localhost:6379"      # pub/sub для мульти-инстанс
FIREBASE_ENABLED="false"               # push-уведомления (требует fbk.json)
